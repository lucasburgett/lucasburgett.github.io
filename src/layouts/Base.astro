---
import "../styles/global.css";
import { site } from "../data/content";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `${site.name} — ${site.role}`,
  description = "Lucas Burgett is a Stanford math major working in reinforcement learning for robotics — training vision-language models with RL for long-horizon robot memory, and joining Parametric (YC F25) this summer.",
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? "https://lucasburgett.com").href;
const ogImage = new URL("/og.png", Astro.site ?? "https://lucasburgett.com").href;
---

<!doctype html>
<html lang="en" class="no-transitions">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="author" content={site.name} />
    <meta name="theme-color" content="#fbfbf9" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#16171d" media="(prefers-color-scheme: dark)" />

    <!-- Open Graph / Twitter -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Set theme + mark JS active before first paint (avoids theme flash and
         keeps reveal animations a progressive enhancement: content is visible
         by default, hidden-until-revealed only when JS is running). -->
    <script is:inline>
      (() => {
        document.documentElement.classList.add("js");
        try {
          const stored = localStorage.getItem("theme");
          const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
          if (stored === "dark" || (!stored && prefersDark)) {
            document.documentElement.classList.add("dark");
          }
        } catch (_) {}
      })();
    </script>

    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Person",
        name: site.name,
        url: canonical,
        email: site.email,
        jobTitle: "Reinforcement Learning Researcher",
        alumniOf: "Stanford University",
        sameAs: [
          "https://github.com/lucasburgett",
          "https://www.linkedin.com/in/lucas-burgett-494a98207",
        ],
      })}
    />
  </head>
  <body>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-accent focus:px-4 focus:py-2 focus:text-accent-contrast"
      >Skip to content</a
    >
    <Nav />
    <main id="main">
      <slot />
    </main>
    <Footer />

    <script>
      // Remove the no-flash guard once the page is interactive so theme changes animate.
      requestAnimationFrame(() => {
        document.documentElement.classList.remove("no-transitions");
      });

      // Theme toggle
      const toggle = () => {
        const root = document.documentElement;
        const isDark = root.classList.toggle("dark");
        try {
          localStorage.setItem("theme", isDark ? "dark" : "light");
        } catch (_) {}
      };
      document.querySelectorAll<HTMLButtonElement>("[data-theme-toggle]").forEach((btn) => {
        btn.addEventListener("click", toggle);
      });

      // Reveal-on-scroll for elements marked [data-reveal]
      const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const revealEls = document.querySelectorAll<HTMLElement>("[data-reveal]");
      if (reduceMotion || !("IntersectionObserver" in window)) {
        revealEls.forEach((el) => el.classList.add("is-visible"));
      } else {
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                io.unobserve(entry.target);
              }
            }
          },
          { rootMargin: "0px 0px -8% 0px", threshold: 0.1 },
        );
        revealEls.forEach((el) => io.observe(el));
      }

      // Active section highlighting in the nav
      const navLinks = Array.from(
        document.querySelectorAll<HTMLAnchorElement>("[data-nav-link]"),
      );
      const sections = navLinks
        .map((link) => document.querySelector<HTMLElement>(link.hash))
        .filter((el): el is HTMLElement => el !== null);
      if ("IntersectionObserver" in window && sections.length) {
        const spy = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                const id = entry.target.id;
                navLinks.forEach((link) =>
                  link.toggleAttribute("data-active", link.hash === `#${id}`),
                );
              }
            }
          },
          { rootMargin: "-45% 0px -50% 0px", threshold: 0 },
        );
        sections.forEach((section) => spy.observe(section));
      }
    </script>
  </body>
</html>
