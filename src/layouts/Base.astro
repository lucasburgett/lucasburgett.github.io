---
import "../styles/global.css";
import { site } from "../data/content";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `${site.name} · ${site.role}`,
  description = "Lucas Burgett is a Stanford math major working in reinforcement learning for robotics. He trains vision-language models with RL for long-horizon robot memory and is interning at Parametric (YC F25) this summer.",
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? "https://lucasburgett.com").href;
const ogImage = new URL("/og.png", Astro.site ?? "https://lucasburgett.com").href;
// Site-wide origin for stable JSON-LD @id anchors (WebSite/Person are singletons;
// ProfilePage is per-page). e.g. https://lucasburgett.com/
const siteUrl = new URL(Astro.site ?? "https://lucasburgett.com").href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="author" content={site.name} />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#f8f6f0" />
    <meta name="google-site-verification" content="iASbm3BFs_axlTdM-GdW5dfidV79c303HGuwut_yxKk" />

    <!-- Open Graph / Twitter -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${site.name} — ${site.role}`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@graph": [
          {
            "@type": "WebSite",
            "@id": `${siteUrl}#website`,
            url: siteUrl,
            name: site.name,
            publisher: { "@id": `${siteUrl}#person` },
            inLanguage: "en-US",
          },
          {
            "@type": "ProfilePage",
            "@id": `${canonical}#profilepage`,
            url: canonical,
            name: title,
            isPartOf: { "@id": `${siteUrl}#website` },
            about: { "@id": `${siteUrl}#person` },
            mainEntity: { "@id": `${siteUrl}#person` },
            inLanguage: "en-US",
          },
          {
            "@type": "Person",
            "@id": `${siteUrl}#person`,
            name: site.name,
            url: siteUrl,
            image: ogImage,
            email: site.email,
            jobTitle: "Reinforcement Learning Researcher",
            alumniOf: { "@type": "CollegeOrUniversity", name: "Stanford University" },
            worksFor: { "@type": "Organization", name: "Parametric" },
            knowsAbout: [
              "Reinforcement Learning",
              "Robotics",
              "Vision-Language Models",
              "Machine Learning",
            ],
            sameAs: [
              "https://github.com/lucasburgett",
              "https://www.linkedin.com/in/lucas-burgett-494a98207",
            ],
            mainEntityOfPage: { "@id": `${canonical}#profilepage` },
          },
        ],
      })}
    />
  </head>
  <body>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-accent focus:px-4 focus:py-2 focus:text-accent-contrast"
      >Skip to content</a
    >
    <Nav />
    <main id="main">
      <slot />
    </main>
    <Footer />

    <script>
      // Sticky nav gains a faint bottom rule once the page scrolls past the top.
      const navEl = document.querySelector<HTMLElement>(".site-nav");
      const onScroll = () => navEl?.toggleAttribute("data-scrolled", window.scrollY > 8);
      if (navEl) {
        onScroll();
        window.addEventListener("scroll", onScroll, { passive: true });
      }

      // Active-section highlighting for wayfinding (progressive enhancement).
      const navLinks = Array.from(
        document.querySelectorAll<HTMLAnchorElement>("[data-nav-link]"),
      );
      const sections = navLinks
        .map((link) => document.querySelector<HTMLElement>(link.hash))
        .filter((el): el is HTMLElement => el !== null);
      if ("IntersectionObserver" in window && sections.length) {
        const spy = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                const id = entry.target.id;
                navLinks.forEach((link) =>
                  link.toggleAttribute("data-active", link.hash === `#${id}`),
                );
              }
            }
          },
          { rootMargin: "-45% 0px -50% 0px", threshold: 0 },
        );
        sections.forEach((section) => spy.observe(section));
      }
    </script>
  </body>
</html>
