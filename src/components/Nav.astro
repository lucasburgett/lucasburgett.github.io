---
const links = [
  { label: "Projects & Personal Research", href: "#work" },
  { label: "Experience", href: "#experience" },
  { label: "About", href: "#about" },
];
---

<header class="site-nav sticky top-0 z-40 border-b border-transparent bg-paper/95">
  <nav class="shell flex h-[4.25rem] items-center justify-between gap-4" aria-label="Primary">
    <a href="#top" class="font-display text-lg tracking-tight text-ink" style="font-weight: 460;"
      >Lucas Burgett</a
    >
    <ul class="hidden items-center gap-6 sm:flex">
      {
        links.map((link) => (
          <li>
            <a
              data-nav-link
              href={link.href}
              class="font-mono text-[0.78rem] tracking-wide text-muted transition-colors hover:text-ink data-[active]:text-accent"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>
