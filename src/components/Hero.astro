---
import { site, socials, now } from "../data/content";

const github = socials.find((s) => s.label === "GitHub");
const linkedin = socials.find((s) => s.label === "LinkedIn");
---

<section id="top" class="shell pb-16 pt-24 md:pb-24 md:pt-28">
  <h1
    class="ed-enter font-display text-ink"
    style="font-weight: 340; font-size: clamp(3.1rem, 8.5vw, 5.6rem); line-height: 0.98; letter-spacing: -0.025em;"
  >
    Lucas Burgett
  </h1>

  <p class="measure mt-7 text-xl leading-relaxed text-body md:text-2xl">
    {site.heroLead}
  </p>

  <p class="mono mt-6 text-sm text-muted">
    {site.role} · {site.location}
  </p>

  <nav class="mt-7 flex flex-wrap items-center gap-x-6 gap-y-3 text-base" aria-label="Profile links">
    <a href={site.resume} class="link-quiet inline-flex min-h-11 items-center">Resume ↗</a>
    <a href={github?.href} target="_blank" rel="noopener" class="link-quiet inline-flex min-h-11 items-center"
      >GitHub</a
    >
    <a href={linkedin?.href} target="_blank" rel="noopener" class="link-quiet inline-flex min-h-11 items-center"
      >LinkedIn</a
    >
    <a href={`mailto:${site.email}`} class="link-quiet inline-flex min-h-11 items-center">Email</a>
  </nav>

  <!-- Currently -->
  <div class="measure mt-14 grid gap-x-10 gap-y-8 sm:grid-cols-2">
    <div>
      <p class="label">{now.summer.label} — {now.summer.org} ({now.summer.badge})</p>
      <p class="mt-2 font-display text-xl text-ink" style="font-weight: 460; letter-spacing: -0.01em;">
        {now.summer.role}
      </p>
      <p class="mt-1.5 text-base leading-relaxed text-muted">{now.summer.detail}</p>
    </div>
    <div>
      <p class="label">{now.research.label} — {now.research.org}</p>
      <p class="mt-2 font-display text-xl text-ink" style="font-weight: 460; letter-spacing: -0.01em;">
        Research Assistant
      </p>
      <p class="mt-1.5 text-base leading-relaxed text-muted">{now.research.detail}</p>
    </div>
  </div>
</section>
