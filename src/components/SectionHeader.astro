---
interface Props {
  index: string;
  eyebrow: string;
  title: string;
  lead?: string;
}
const { index, eyebrow, title, lead } = Astro.props;
---

<div class="mb-14 md:mb-20" data-reveal>
  <div class="flex items-center gap-3">
    <span class="font-mono text-xs text-accent">{index}</span>
    <span class="eyebrow">{eyebrow}</span>
    <span class="h-px flex-1 bg-line" data-draw></span>
  </div>
  <h2
    class="mt-5 max-w-4xl text-balance text-4xl font-semibold leading-[1.02] tracking-[-0.025em] text-ink sm:text-5xl md:text-6xl"
  >
    {title}
  </h2>
  {lead && <p class="mt-5 max-w-2xl text-lg leading-relaxed text-muted md:text-xl">{lead}</p>}
</div>
