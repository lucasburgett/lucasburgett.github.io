---
interface Props {
  index: string;
  eyebrow: string;
  title: string;
  lead?: string;
}
const { index, eyebrow, title, lead } = Astro.props;
---

<div class="mb-12 md:mb-16" data-reveal>
  <div class="flex items-center gap-3">
    <span class="font-mono text-xs text-accent">{index}</span>
    <span class="eyebrow">{eyebrow}</span>
    <span class="h-px flex-1 bg-line" data-draw></span>
  </div>
  <h2 class="mt-4 max-w-3xl text-balance text-3xl font-semibold tracking-tight text-ink md:text-4xl">
    {title}
  </h2>
  {lead && <p class="mt-4 max-w-2xl text-base leading-relaxed text-muted md:text-lg">{lead}</p>}
</div>
