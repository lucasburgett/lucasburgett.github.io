---
interface Props {
  index: string;
  eyebrow: string;
  title: string;
  lead?: string;
}
const { index, eyebrow, title, lead } = Astro.props;
---

<div class="mb-10 border-t border-line pt-6 md:mb-14">
  <p class="label">{index} &nbsp;·&nbsp; {eyebrow}</p>
  <h2
    class="mt-3 max-w-3xl font-display text-3xl font-normal tracking-tight text-ink md:text-4xl"
    style="font-weight: 420; letter-spacing: -0.018em;"
  >
    {title}
  </h2>
  {lead && <p class="measure mt-4 text-lg leading-relaxed text-muted">{lead}</p>}
</div>
