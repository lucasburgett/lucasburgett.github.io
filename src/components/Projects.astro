---
import SectionHeader from "./SectionHeader.astro";
import { projects } from "../data/content";
---

<section id="projects" class="scroll-mt-20 py-20 md:py-28">
  <div class="shell">
    <SectionHeader
      index="02"
      eyebrow="Projects"
      title="Things I've shipped"
      lead="Work outside the lab: AI products, developer tools, and models built to run, not just train. Some repos are private; I link the source where it's public."
    />

    <div class="proj-list border-b border-line" data-reveal>
      {
        projects.map((project, i) => {
          const Row = project.href ? "a" : "div";
          const rowProps = project.href
            ? { href: project.href, target: "_blank", rel: "noopener" }
            : {};
          const index = String(i + 1).padStart(2, "0");
          return (
            <Row
              {...rowProps}
              class="proj-row group block border-t border-line py-8 md:py-10"
            >
              <div class="flex items-start justify-between gap-5 md:gap-10">
                <div class="min-w-0">
                  <p class="font-mono text-[0.7rem] uppercase tracking-wider text-faint">
                    <span class="text-accent-ink">{index}</span>
                    <span class="px-1.5 text-line-strong">/</span>
                    {project.kind}
                    <span class="px-1.5 text-line-strong">·</span>
                    {project.year}
                  </p>
                  <h3 class="mt-3 text-3xl font-semibold tracking-[-0.02em] text-ink transition-colors duration-300 group-hover:text-accent-ink sm:text-4xl md:text-5xl">
                    {project.title}
                  </h3>
                  <p class="mt-4 max-w-2xl text-sm leading-relaxed text-muted md:text-base">
                    {project.body}
                  </p>
                  <ul class="mt-5 flex flex-wrap gap-1.5">
                    {project.tags.map((tag) => (
                      <li class="tag">{tag}</li>
                    ))}
                  </ul>
                </div>

                <div class="flex-none pt-1.5">
                  {project.href ? (
                    <span
                      class="grid h-11 w-11 place-items-center rounded-full border border-line text-muted transition-all duration-300 group-hover:border-accent group-hover:bg-accent-soft group-hover:text-accent-ink"
                      aria-hidden="true"
                    >
                      <svg
                        class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <path d="M7 17 17 7M9 7h8v8" />
                      </svg>
                    </span>
                  ) : (
                    <span
                      class="grid h-11 w-11 place-items-center rounded-full border border-line text-faint"
                      title={project.repoPrivate ? "Private repository" : "Source unavailable"}
                      aria-label={project.repoPrivate ? "Private repository" : "Source unavailable"}
                    >
                      <svg
                        class="h-4 w-4"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.7"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                      >
                        <rect x="5" y="11" width="14" height="10" rx="2" />
                        <path d="M8 11V7a4 4 0 0 1 8 0v4" />
                      </svg>
                    </span>
                  )}
                </div>
              </div>
            </Row>
          );
        })
      }
    </div>
  </div>
</section>
