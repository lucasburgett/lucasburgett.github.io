---
import SectionHeader from "./SectionHeader.astro";
import { projects } from "../data/content";
---

<section id="projects" class="shell scroll-mt-24 py-20 md:py-28">
  <SectionHeader
    index="02"
    eyebrow="Building"
    title="Things I've shipped"
    lead="Work outside the lab: AI products, developer tools, and models built to run, not just train. Some repos are private; I link the source where it's public."
  />

  <div class="measure">
    {
      projects.map((project) => (
        <article class="border-t border-line py-7 last:border-b">
          <div class="flex items-baseline justify-between gap-4">
            <h3
              class="font-display text-2xl text-ink"
              style="font-weight: 420; letter-spacing: -0.012em;"
            >
              {project.title}
            </h3>
            <span class="label flex-none">
              {project.kind} · {project.year}
            </span>
          </div>
          <p class="mt-3 leading-relaxed text-muted">{project.body}</p>
          <p class="mono mt-4 text-sm leading-relaxed text-muted">{project.tags.join("  ·  ")}</p>
          <p class="mt-4">
            {project.href ? (
              <a href={project.href} target="_blank" rel="noopener" class="link font-mono text-sm">
                {project.hrefLabel ?? "View source"} ↗
              </a>
            ) : (
              <span class="mono text-sm text-faint">
                {project.repoPrivate ? "Private repository" : "Source unavailable"}
              </span>
            )}
          </p>
        </article>
      ))
    }
  </div>
</section>
