---
import SectionHeader from "./SectionHeader.astro";
import { site, education, skills } from "../data/content";
---

<section id="about" class="scroll-mt-20 py-20 md:py-28">
  <div class="shell">
    <SectionHeader index="04" eyebrow="About" title="A little more" />

    <div class="grid gap-12 md:grid-cols-[1.25fr_1fr] md:gap-16">
      <div data-reveal>
        <div class="space-y-4 text-base leading-relaxed text-muted md:text-lg">
          {site.about.map((p) => <p>{p}</p>)}
        </div>

        <div class="mt-10 rounded-2xl border border-line bg-surface p-6 shadow-[var(--shadow)]">
          <p class="eyebrow">Education</p>
          <h3 class="mt-3 text-lg font-semibold tracking-tight text-ink">{education.school}</h3>
          <p class="mt-1 text-sm text-muted">{education.degree}</p>
          <div class="mt-2 flex flex-wrap items-center gap-x-3 gap-y-1 font-mono text-xs text-faint">
            <span>{education.period}</span>
            <span class="h-1 w-1 rounded-full bg-line-strong"></span>
            <span>{education.detail}</span>
          </div>
        </div>
      </div>

      <div class="space-y-10" data-reveal style="--reveal-delay: 100ms">
        <div>
          <p class="eyebrow">Toolbox</p>
          <dl class="mt-5 space-y-5">
            {
              skills.map((group) => (
                <div class="grid grid-cols-[5.5rem_1fr] gap-3 sm:grid-cols-[7rem_1fr]">
                  <dt class="pt-0.5 font-mono text-[0.7rem] uppercase tracking-wider text-faint">
                    {group.label}
                  </dt>
                  <dd class="flex flex-wrap gap-1.5">
                    {group.items.map((item) => (
                      <span class="tag">{item}</span>
                    ))}
                  </dd>
                </div>
              ))
            }
          </dl>
        </div>

        <div>
          <p class="eyebrow">Selected coursework</p>
          <ul class="mt-5 space-y-2.5">
            {
              education.coursework.map((course) => (
                <li class="flex gap-3 text-sm text-muted">
                  <span class="w-[4.2rem] flex-none pt-px font-mono text-[0.7rem] text-accent-ink">
                    {course.code}
                  </span>
                  <span>{course.title}</span>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>
