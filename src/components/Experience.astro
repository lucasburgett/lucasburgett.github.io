---
import SectionHeader from "./SectionHeader.astro";
import { experience } from "../data/content";
---

<section id="experience" class="shell scroll-mt-24 py-20 md:py-28">
  <SectionHeader
    index="03"
    eyebrow="Experience"
    title="Where I've worked"
    lead="From production computer vision to startup research. This summer, reinforcement learning for robots at Parametric."
  />

  <div class="measure">
    {
      experience.map((job) => (
        <article class="grid gap-x-8 gap-y-2 border-t border-line py-7 md:grid-cols-[9rem_1fr]">
          <p class="mono pt-1 text-[0.78rem] tracking-wide text-faint">
            {job.period}
            {job.upcoming && <span class="mt-1 block text-accent">Incoming</span>}
          </p>
          <div>
            <h3
              class="font-display text-xl text-ink"
              style="font-weight: 440; letter-spacing: -0.01em;"
            >
              {job.role}
              <span class="text-muted"> · {job.org}</span>
            </h3>
            <p class="label mt-1">{job.location}</p>
            <p class="mt-3 leading-relaxed text-muted">{job.body}</p>
            {job.tags && (
              <p class="mono mt-3 text-sm leading-relaxed text-muted">{job.tags.join("  ·  ")}</p>
            )}
          </div>
        </article>
      ))
    }
  </div>
</section>
