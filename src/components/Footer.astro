---
import { site, socials } from "../data/content";
const year = 2026;
const github = socials.find((s) => s.label === "GitHub");
const linkedin = socials.find((s) => s.label === "LinkedIn");
---

<footer id="contact" class="shell scroll-mt-24 border-t border-line py-20 md:py-24">
  <p class="label">Contact</p>
  <p
    class="measure mt-4 font-display text-2xl leading-snug text-ink md:text-3xl"
    style="font-weight: 420; letter-spacing: -0.015em;"
  >
    The fastest way to reach me is email.
  </p>
  <p class="mt-4">
    <a href={`mailto:${site.email}`} class="link text-lg">{site.email}</a>
  </p>

  <div class="mt-8 flex flex-wrap gap-x-6 gap-y-3">
    <a href={github?.href} target="_blank" rel="noopener" class="link-quiet inline-flex min-h-11 items-center"
      >GitHub</a
    >
    <a href={linkedin?.href} target="_blank" rel="noopener" class="link-quiet inline-flex min-h-11 items-center"
      >LinkedIn</a
    >
    <a href={site.resume} class="link-quiet inline-flex min-h-11 items-center">Resume ↗</a>
  </div>

  <div
    class="mono mt-14 flex flex-col gap-2 border-t border-line pt-6 text-xs text-faint sm:flex-row sm:items-center sm:justify-between"
  >
    <p>© {year} {site.name}</p>
    <p>{site.location}</p>
    <p>Built with Astro &amp; Tailwind</p>
  </div>
</footer>
